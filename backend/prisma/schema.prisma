// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================
// User & Family
// ============================================
model User {
  id         String    @id @default(cuid())
  email      String    @unique
  name       String
  role       String?
  globalRole String    @default("USER")
  birthday   DateTime?
  familyId   String?
  family     Family?   @relation("LegacyFamily", fields: [familyId], references: [id], onDelete: SetNull)
  families   Family[]  @relation("UserFamilies")

  googleId             String? @unique
  avatarUrl            String?
  notificationSettings Json?   @default("{}")

  createdEvents   Event[]
  mealPreferences MealPreference[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notifications Notification[]
  pushSubscriptions PushSubscription[]
  transactions Transaction[]
  budgets      Budget[]
}

model Family {
  id          String @id @default(cuid())
  name        String
  users       User[] @relation("UserFamilies")
  legacyUsers User[] @relation("LegacyFamily")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// Calendar & Events
// ============================================
model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  date        DateTime // Solar date
  time        String? // Ex: "09:00"
  lunarDate   String? // Ex: "30/12" (day/month in lunar calendar)
  type        EventType @default(GENERAL)

  isRecurring Boolean @default(false)
  recurring   String? // CRON expression (if recurring)

  familyId  String
  createdBy String
  user      User   @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  scope EventScope @default(GLOBAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([familyId])
}

enum EventType {
  BIRTHDAY
  ANNIVERSARY
  HOLIDAY
  APPOINTMENT
  TASK
  GENERAL
}

enum EventScope {
  PRIVATE
  FAMILY
  GLOBAL
}

// ============================================
// Meals & Preferences
// ============================================
model Meal {
  id       String       @id @default(cuid())
  name     String
  category MealCategory
  tags     String[] // ["healthy", "fast", "vegan", etc.]

  preferences MealPreference[]
  history     MealHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MealCategory {
  MAIN_COURSE
  VEGETABLE
  SOUP
}

model MealPreference {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealId String
  meal   Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, mealId])
}

model MealHistory {
  id       String       @id @default(cuid())
  mealId   String
  meal     Meal         @relation(fields: [mealId], references: [id], onDelete: Cascade)
  date     DateTime
  category MealCategory
  familyId String       @default("default-family")

  createdAt DateTime @default(now())

  @@index([date])
  @@index([mealId])
  @@index([familyId])
}

// ============================================
// AI Chat
// ============================================
model ChatSession {
  id       String @id @default(cuid())
  familyId String
  title    String

  messages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([familyId])
}

model ChatMessage {
  id        String       @id @default(cuid())
  familyId  String
  sessionId String?
  session   ChatSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String // "user" or "assistant"
  content   String

  createdAt DateTime @default(now())

  @@index([familyId])
  @@index([sessionId])
  @@index([createdAt])
}

// ============================================
// Notifications
// ============================================
model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type     String // e.g., "EVENT_CREATED", "MEAL_ADDED"
  title    String
  message  String
  metadata Json? // { eventId: "...", path: "/calendar" }

  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ============================================
// Web Push Notifications
// ============================================
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String

  createdAt DateTime @default(now())

  @@index([userId])
}

// ============================================
// Finance & Budgeting
// ============================================
model Transaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  amount      Float
  type        TransactionType @default(EXPENSE)
  category    TransactionCategory @default(OTHER)
  description String?
  date        DateTime @default(now())
  
  // PayOS specific metadata
  reference   String?  @unique // Bank reference number
  paymentId   String?  @unique // PayOS payment ID
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([date])
}

model Budget {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  monthlyIncome Float    @default(0)
  dailyBudget   Float    @default(0)
  month         Int
  year          Int
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, month, year])
  @@index([userId])
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionCategory {
  FOOD            // Ăn uống
  TRANSPORT       // Di chuyển
  SHOPPING        // Mua sắm
  UTILITIES       // Tiền điện/nước/mạng
  RENT            // Tiền nhà
  ENTERTAINMENT   // Giải trí
  HEALTH          // Sức khỏe
  EDUCATION       // Giáo dục
  SALARY          // Lương (Income)
  BONUS           // Thưởng (Income)
  INVESTMENT      // Đầu tư
  OTHER           // Khác
}
