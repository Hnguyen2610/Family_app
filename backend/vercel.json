{
  "version": 2,
  "builds": [
    {
      "src": "src/main.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/main.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/notifications/daily",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/notifications/monthly",
      "schedule": "0 1 1 * *"
    }
  ]
}
